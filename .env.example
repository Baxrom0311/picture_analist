# Django
DEBUG=True
# Development only. Production will refuse to start with the placeholder value.
SECRET_KEY=replace-with-a-very-long-random-secret-key-before-production-deploy-2026
ALLOWED_HOSTS=localhost,127.0.0.1
ADMIN_URL=admin/

# Database (SQLite for dev, PostgreSQL for prod)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=art_evaluation
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# Redis
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery - set to True to run tasks synchronously (no Redis needed)
CELERY_TASK_ALWAYS_EAGER=True

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# AWS S3 / MinIO (optional)
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=art-evaluation-bucket
AWS_S3_REGION_NAME=us-east-1

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_FORMATS=jpeg,jpg,png,webp

# CORS
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# User Credits
DEFAULT_USER_CREDITS=10
